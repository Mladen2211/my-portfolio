{
  "kind": "collectionType",
  "collectionName": "skill_categories",
  "info": {
    "singularName": "skill-category",
    "pluralName": "skill-categories",
    "displayName": "Skill Category",
    "description": "Groups of related skills"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "category": {
      "type": "string",
      "required": true
    },
    "iconName": {
      "type": "string",
      "required": true
    },
    "sortOrder": {
      "type": "integer",
      "required": true,
      "default": 0
    },
    "skillItems": {
      "type": "component",
      "repeatable": true,
      "component": "shared.skill-item"
    }
  }
}
